{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "NormalUser", "BusinessOwner"] },
        "status": { "type": "string" },
        "avatar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Public profile details.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "location": { "type": "string" },
        "followerCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "friendCount": { "type": "number" }
      },
      "required": ["id", "userId"]
    },
    "Follow": {
      "title": "Follow",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Friendship": {
      "title": "Friendship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "PostLike": {
      "title": "PostLike",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Bookmark": {
      "title": "Bookmark",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "postData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Private user account data." },
    "/public_user_profiles/{userId}": { "schema": "UserProfile", "description": "Public user profile info." },
    "/follows/{followId}": { "schema": "Follow", "description": "Following relationships." },
    "/friend_requests/{requestId}": { "schema": "FriendRequest", "description": "Friendship requests." },
    "/friendships/{friendshipId}": { "schema": "Friendship", "description": "Mutual friendships." },
    "/conversations/{conversationId}": { "schema": "Conversation", "description": "Chat conversations." },
    "/messages/{messageId}": { "schema": "Message", "description": "Individual chat messages." },
    "/post_likes/{likeId}": { "schema": "PostLike", "description": "User likes on posts." },
    "/bookmarks/{bookmarkId}": { "schema": "Bookmark", "description": "User saved posts." }
  }
}
