
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "NormalUser", "BusinessOwner"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Public profile details.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "location": { "type": "string" }
      },
      "required": ["id", "userId"]
    },
    "Business": {
      "title": "Business",
      "type": "object",
      "description": "Local business profile.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["id", "ownerId", "name", "categoryId", "status"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Social feed post.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "content", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "User notification for social activities.",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string" },
        "actorName": { "type": "string" },
        "actorAvatar": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "recipientId", "actorName", "type", "message", "read", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Private user account data." },
    "/public_user_profiles/{userId}": { "schema": "UserProfile", "description": "Public user profile info." },
    "/businesses/{businessId}": { "schema": "Business", "description": "Local businesses." },
    "/posts/{postId}": { "schema": "Post", "description": "Social posts." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User activity notifications." }
  }
}
