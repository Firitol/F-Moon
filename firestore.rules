
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - PUBLIC ACCESS MODE
 * 
 * This configuration allows open read and write access for all users during development.
 * 
 * DEPLOYMENT_FORCE_ID: 2024_05_24_COMMENT_STABILITY_V112
 */

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
