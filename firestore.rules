
rules_version = '2';

/**
 * F-MOON FIRESTORE SECURITY RULES - DEVELOPMENT MODE
 * Deployment Trigger: 2024-05-21T15:05:00Z
 * 
 * WARNING: These rules allow read and write access to any user (including unauthenticated ones).
 * This is intended ONLY for development and rapid prototyping to resolve permission errors.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
