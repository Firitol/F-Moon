
rules_version = '2';

/**
 * F-MOON FIRESTORE SECURITY RULES
 * Updated: 2024-05-21 (Fixing list permissions)
 *
 * Core Philosophy:
 * This ruleset implements a robust, multi-tiered authorization model. 
 * It prioritizes User Ownership and Global Admin privileges. 
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is a global administrator. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates that a field is not being changed during an update. */
    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    /**
     * @description Core user account data. Private to the user and admins.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isExistingOwner(userId) && isUnchanged('role')) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Publicly accessible user profile details.
     */
    match /public_user_profiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Marker collection for administrator privileges.
     */
    match /admin_roles/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    /**
     * @description Business categories lookup table.
     */
    match /business_categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Business profiles. 
     */
    match /businesses/{businessId} {
      allow get: if resource == null || isAdmin() || resource.data.status == 'active' || isOwner(resource.data.ownerId);
      // QAP: Fix list rule - use resource.data instead of request.query
      allow list: if isAdmin() 
                  || (resource.data.status == 'active')
                  || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.ownerId) && isUnchanged('ownerId')) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Subscription plans lookup table.
     */
    match /subscription_plans/{planId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Business subscriptions.
     */
    match /business_subscriptions/{subscriptionId} {
      allow get: if resource == null || isOwner(resource.data.ownerId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    /**
     * @description User-generated posts.
     */
    match /posts/{postId} {
      allow get: if resource == null || isAdmin() || resource.data.status == 'active' || isOwner(resource.data.authorId);
      // QAP: Fix list rule - use resource.data instead of request.query
      allow list: if isAdmin() 
                  || (resource.data.status == 'active')
                  || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.authorId) && isUnchanged('authorId')) || isAdmin();
      allow delete: if isExistingOwner(resource.data.authorId) || isAdmin();

      match /comments/{commentId} {
        allow get, list: if true; // Publicly readable for active threads
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if (isExistingOwner(resource.data.authorId) && isUnchanged('authorId')) || isAdmin();
        allow delete: if isExistingOwner(resource.data.authorId) || isAdmin();
      }

      match /likes/{userId} {
        allow get, list: if true;
        allow create: if isOwner(userId);
        allow delete: if isExistingOwner(userId) || isAdmin();
        allow update: if false;
      }
    }

    /**
     * @description Social graph (follows).
     */
    match /follows/{followId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isExistingOwner(resource.data.followerId) || isAdmin();
    }

    /**
     * @description Financial transaction records.
     */
    match /payments/{paymentId} {
      allow get: if resource == null || isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    /**
     * @description Moderation reports.
     */
    match /reports/{reportId} {
      allow get: if resource == null || isOwner(resource.data.reporterId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.reporterId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Real-time notifications for users.
     */
    match /notifications/{notificationId} {
      allow get: if resource == null || isAdmin() || (isSignedIn() && resource.data.recipientId == request.auth.uid);
      // QAP: Fix list rule - use resource.data instead of request.query
      allow list: if isAdmin() || (isSignedIn() && resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isExistingOwner(resource.data.recipientId));
    }
  }
}
