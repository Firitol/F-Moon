rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - PUBLIC ACCESS MODE
 * 
 * This configuration allows open read and write access for all users during development.
 * 
 * DEPLOYMENT_FORCE_ID: 2024_05_23_SOCIAL_GRAPH_V105_PUBLIC
 */

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}