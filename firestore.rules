rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - FULL PUBLIC ACCESS (DEVELOPMENT MODE)
 * Deployment Trigger: 2024-05-22T09:15:00Z
 * This configuration allows anyone with your database reference to view, edit, and delete all data.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}